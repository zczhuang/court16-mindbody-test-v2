# ─────────────────────────────────────────────────────────────────────────────
# MindBody Public API v6 — sandbox credentials
# ─────────────────────────────────────────────────────────────────────────────
# To run this test you need THREE things:
#   1. An Api-Key (from developers.mindbodyonline.com — free developer account)
#   2. A Site ID (for the sandbox, use -99)
#   3. Staff credentials that can issue a StaffUserToken
#
# The "-99" public sandbox accepts well-known staff credentials:
#   Username: Siteowner       Password: apitest1234
# (This is the form documented by MindBody for the -99 sandbox.)
#
# Stuart also received a sandbox login framed as:
#   Username: mindbodysandboxsite@gmail.com   Password: Apitest1234
# If one doesn't work, try the other — they're the same sandbox, different
# credential conventions.
# ─────────────────────────────────────────────────────────────────────────────

MINDBODY_API_KEY=paste-your-api-key-here
MINDBODY_SITE_ID=-99
MINDBODY_STAFF_USERNAME=Siteowner
MINDBODY_STAFF_PASSWORD=apitest1234

# Base URL — don't change unless MindBody moves their endpoint.
MINDBODY_BASE_URL=https://api.mindbodyonline.com/public/v6

# SAFETY SWITCH — keep this "test" until we've eyeballed every path end-to-end.
# Values:
#   test   → every write call sends Test=true (MindBody accepts, does nothing permanent)
#   live   → writes are real. Requires explicit flip + code review.
MINDBODY_WRITE_MODE=test

# Dev escape hatch: force /api/mindbody/calendar to query MINDBODY_SITE_ID
# (e.g. -99 sandbox) regardless of the user's location selection. Use this
# until Anthony authorizes the dev Api-Key against the 6 production Site IDs.
MINDBODY_USE_SANDBOX_FALLBACK=false

# Optional: if set, API routes require this bearer token. Leave blank for open sandbox testing.
TEST_API_TOKEN=

# Optional: seed email used by the happy-path endpoint when none is supplied.
# Uses a plus-address so you can keep using the same inbox for repeated runs.
HAPPY_PATH_DEFAULT_EMAIL=stuart+mbtest@cedarwind.io

# ─────────────────────────────────────────────────────────────────────────────
# HubSpot Private App — Track 1 owns CRM + every email via Workflows
# ─────────────────────────────────────────────────────────────────────────────
# Create a Private App in HubSpot (Settings → Integrations → Private Apps)
# with the scopes listed in docs/hubspot-schema.md. Paste the access token
# below. Missing values = HubSpot calls are no-op'd (route still runs
# MindBody writes). Set HUBSPOT_REQUIRED=true to make HubSpot a hard dep.
HUBSPOT_ACCESS_TOKEN=

# Set to "sandbox" in dev, "production" in prod. Kept separate so we never
# touch the 134K-contact production portal from localhost.
HUBSPOT_ENV=sandbox

# HubSpot portal ID (owned by Ibtissam). Stays constant.
HUBSPOT_PORTAL_ID=4832170

# Existing kids-trial form GUID at share.hsforms.com/1PpZqxIcuSeybkx8RT6bTmw2vkiy.
# We submit to this form via the Forms API v3 Integration endpoint, so the
# existing nurture workflows keep firing. See docs/hubspot-properties.md
# for the required custom properties Ibtissam must add to the Contact.
HUBSPOT_TRIAL_FORM_GUID=3e966ac4-872e-49ec-9b93-1f114fa6d39b

# Optional overrides — only set if hitting HubSpot EU or a test host.
# HUBSPOT_API_BASE_URL=https://api.hubapi.com
# HUBSPOT_FORMS_BASE_URL=https://api.hsforms.com

# Optional — set to "true" to refuse to boot if HUBSPOT_ACCESS_TOKEN /
# HUBSPOT_CUSTOM_OBJECT_TYPE_ID are missing. Useful in staging/prod.
HUBSPOT_REQUIRED=

# ─────────────────────────────────────────────────────────────────────────────
# Signed-token infrastructure for staff confirm/reassign/admin-retry URLs
# ─────────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# MUST be >= 32 chars. Rotate on suspected exposure.
STAFF_CONFIRM_SIGNING_SECRET=

# Fully-qualified base URL used when stamping signed URLs into email bodies.
# Local dev: http://localhost:3000
# Production: https://app.court16.com (or whatever the Vercel alias is)
APP_BASE_URL=http://localhost:3000

# Where to send staff trial notifications. Per-location overrides live in
# lib/config.ts (staffNotifyEmailOverride on each LocationConfig).
STAFF_NOTIFY_EMAIL=

# Optional Slack webhook for booking-failed alerts. Leave blank to disable.
SLACK_ALERT_WEBHOOK=

# ─────────────────────────────────────────────────────────────────────────────
# Phase 2 client tracker (/tracker.html) comment store
# ─────────────────────────────────────────────────────────────────────────────
# Comments from the Phase 2 tracker are stored as GitHub Issues in a private
# repo. Stuart gets email notifications via GitHub's native watch behavior
# (default on repos you own). Create a fine-grained PAT with Issues: Read+Write
# scoped to just zczhuang/court16-tracker-comments.
#
# Leave unset to disable the comment thread (the tracker still renders; the
# thread panel shows "not yet configured").
TRACKER_GITHUB_TOKEN=
TRACKER_REPO_OWNER=zczhuang
TRACKER_REPO_NAME=court16-tracker-comments
TRACKER_LABEL=tracker-feedback
